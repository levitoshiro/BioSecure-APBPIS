# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Blockchain Configuration (Optional for demo, required for real blockchain)
# RPC_URL: The RPC endpoint for your blockchain (e.g., Infura, Alchemy, or local Hardhat node)
RPC_URL="http://127.0.0.1:8545"
# PRIVATE_KEY: The private key of the account deploying/interacting with the contract
PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"
# CONTRACT_ADDRESS: The deployed address of the MedicalRecords.sol contract
CONTRACT_ADDRESS="0xYourContractAddressHere"
